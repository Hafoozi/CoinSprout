# Supabase — copy these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Used only in server-side code (never exposed to the browser)
# Copy from Supabase project settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
